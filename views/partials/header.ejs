<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — مزایده' : 'مزایده' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site">
    <div class="wrap site-header-inner">
      <a class="brand" href="/">🔨 مزایده <small>حراج آنلاین کالا</small></a>
      <nav class="main-nav">
        <a class="btn btn-ghost" href="/">لات‌های حراج</a>
        <% if (currentUser) { %>
          <a class="btn btn-ghost" href="/dashboard">پیشخوان من</a>
          <a class="btn btn-outline" href="/items/new">+ ثبت کالا برای مزایده</a>
          <form method="POST" action="/logout" style="display:inline;">
            <button type="submit" class="btn btn-ghost">خروج (<%= currentUser.name %>)</button>
          </form>
        <% } else { %>
          <a class="btn btn-ghost" href="/login">ورود</a>
          <a class="btn btn-brass" href="/register">ثبت‌نام رایگان</a>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="wrap">
