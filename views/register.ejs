<% pageTitle = 'ثبت‌نام' %>
<%- include('partials/header') %>

<div class="form-panel">
  <h2>ساخت حساب کاربری</h2>
  <% if (error) { %><div class="form-error"><%= error %></div><% } %>
  <form method="POST" action="/register">
    <div class="field">
      <label>نام و نام خانوادگی</label>
      <input type="text" name="name" required value="<%= values.name || '' %>">
    </div>
    <div class="field">
      <label>ایمیل</label>
      <input type="email" name="email" required value="<%= values.email || '' %>">
    </div>
    <div class="field-row">
      <div class="field">
        <label>رمز عبور</label>
        <input type="password" name="password" required>
      </div>
      <div class="field">
        <label>تکرار رمز عبور</label>
        <input type="password" name="password2" required>
      </div>
    </div>
    <button type="submit" class="btn btn-brass" style="width:100%">ثبت‌نام</button>
  </form>
  <p class="form-note">قبلاً ثبت‌نام کرده‌اید؟ <a href="/login" style="color:var(--brass-bright)">وارد شوید</a></p>
</div>

<%- include('partials/footer') %>
