<% pageTitle = 'ورود' %>
<%- include('partials/header') %>

<div class="form-panel">
  <h2>ورود به حساب کاربری</h2>
  <% if (error) { %><div class="form-error"><%= error %></div><% } %>
  <form method="POST" action="/login">
    <div class="field">
      <label>ایمیل</label>
      <input type="email" name="email" required value="<%= values.email || '' %>">
    </div>
    <div class="field">
      <label>رمز عبور</label>
      <input type="password" name="password" required>
    </div>
    <button type="submit" class="btn btn-brass" style="width:100%">ورود</button>
  </form>
  <p class="form-note">حساب ندارید؟ <a href="/register" style="color:var(--brass-bright)">ثبت‌نام کنید</a></p>
</div>

<%- include('partials/footer') %>
